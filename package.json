{
  "name": "daas-fe",
  "version": "1.0.0",
  "private": true,
  "description": "DataSphere Frontend Library - 数据中台前端库",
  "keywords": [
    "vue3",
    "typescript",
    "element-plus",
    "library",
    "admin",
    "datasphere"
  ],
  "author": "DataSphere Team <chenpan.ai@qq.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm -F @daas-fe/playground dev",
    "build": "pnpm -F @daas-fe/core build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"packages/**/*.{vue,js,ts,tsx,json,css,scss,md}\"",
    "type-check": "vue-tsc --noEmit",
    "clean": "rimraf packages/*/dist packages/*/node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@8.6.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}